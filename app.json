{
  "expo": {
    "name": "PropFirm Guardian",
    "slug": "PropFirmGuardian",
    "version": "2.1.0",
    "description": "Professional risk management calculator for prop firm traders",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.giftobey.propfirmguardian",
      "versionCode": 4,
      "permissions": ["NOTIFICATIONS", "VIBRATE", "RECEIVE_BOOT_COMPLETED"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "b7310a70-0c26-465d-b1eb-8e0fdeaa8c44"
      }
    },
    "owner": "ajviral"
  }
}
